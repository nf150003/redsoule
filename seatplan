<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Save Number</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  height:100vh;
  display:flex;
  justify-content:center;
  align-items:center;
  font-family:'Poppins',sans-serif;
  background:linear-gradient(135deg,#4facfe,#00f2fe,#43e97b);
  overflow:hidden;
}

/* Floating Background */

.bg1,.bg2,.bg3{
  position:absolute;
  border-radius:50%;
  background:rgba(255,255,255,0.15);
  animation:float 6s infinite ease-in-out;
}

.bg1{
  width:220px;
  height:220px;
  top:5%;
  left:5%;
}

.bg2{
  width:150px;
  height:150px;
  bottom:10%;
  right:10%;
  animation-delay:2s;
}

.bg3{
  width:90px;
  height:90px;
  top:70%;
  left:25%;
  animation-delay:4s;
}

@keyframes float{
  0%{transform:translateY(0);}
  50%{transform:translateY(-20px);}
  100%{transform:translateY(0);}
}

/* Card */

.container{
  width:380px;
  padding:35px;
  border-radius:30px;
  background:rgba(255,255,255,0.15);
  backdrop-filter:blur(15px);
  box-shadow:0 10px 30px rgba(0,0,0,0.2);
  text-align:center;
  z-index:10;
  border:1px solid rgba(255,255,255,0.2);
}

.logo{
  width:90px;
  height:90px;
  margin:auto;
  border-radius:50%;
  background:linear-gradient(135deg,#ff9a9e,#fad0c4);
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:40px;
  color:white;
  margin-bottom:20px;
  box-shadow:0 8px 20px rgba(0,0,0,0.15);
}

h1{
  color:white;
  font-size:30px;
  margin-bottom:10px;
}

p{
  color:white;
  opacity:0.9;
  margin-bottom:25px;
}

input{
  width:100%;
  padding:16px;
  border:none;
  border-radius:15px;
  outline:none;
  font-size:18px;
  margin-bottom:20px;
  background:rgba(255,255,255,0.9);
}

button{
  width:100%;
  padding:16px;
  border:none;
  border-radius:15px;
  background:linear-gradient(135deg,#ff758c,#ff7eb3);
  color:white;
  font-size:18px;
  font-weight:600;
  cursor:pointer;
  transition:0.3s;
  box-shadow:0 8px 20px rgba(255,118,136,0.4);
}

button:hover{
  transform:translateY(-3px);
}

#status{
  margin-top:20px;
  color:white;
  font-weight:600;
  font-size:16px;
}

</style>
</head>
<body>

<div class="bg1"></div>
<div class="bg2"></div>
<div class="bg3"></div>

<div class="container">

  <div class="logo">#</div>

  <h1>Save Number</h1>

  <p>Save numbers directly into Google Sheets 🚀</p>

  <input 
    type="number" 
    id="numberInput"
    placeholder="Enter a number">

  <button onclick="saveNumber()">
    Save Data
  </button>

  <div id="status"></div>

</div>

<script>

async function saveNumber(){

  const number = document.getElementById("numberInput").value;
  const status = document.getElementById("status");

  if(number === ""){
    status.innerHTML = "⚠ Enter a number first";
    return;
  }

  status.innerHTML = "⏳ Saving...";

  try{

    const response = await fetch(
      "https://script.google.com/macros/s/AKfycbw1sJatw_bBylJMfsLuUGNrFmAMbFBJAvgPLynNdDGpGVpzMhhfTXkzJViIHr_ed88/exec",
      {
        method:"POST",
        body:JSON.stringify({
          number:number
        })
      }
    );

    const result = await response.json();

    status.innerHTML = "✅ Saved Successfully";

    document.getElementById("numberInput").value = "";

  }catch(error){

    status.innerHTML = "❌ Error Saving Data";

    console.log(error);

  }
}

</script>

</body>
</html>
